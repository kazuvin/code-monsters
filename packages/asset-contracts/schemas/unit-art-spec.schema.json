{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-monsters.local/schemas/unit-art-spec.schema.json",
  "title": "Code Monsters unit art specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "unitId",
    "silhouette",
    "bodyParts",
    "weapon",
    "surfaceMaterials",
    "identityConstraints",
    "negativeConstraints"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "unitId": { "$ref": "#/$defs/stableId" },
    "silhouette": { "type": "string", "minLength": 1 },
    "bodyParts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "weapon": { "type": "string", "minLength": 1 },
    "surfaceMaterials": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "identityConstraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "negativeConstraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "paletteOverrides": {
      "type": "array",
      "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
  }
}
