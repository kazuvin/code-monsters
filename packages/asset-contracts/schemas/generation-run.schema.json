{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-monsters.local/schemas/generation-run.schema.json",
  "title": "Code Monsters sprite generation run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "unitId",
    "motionIds",
    "createdAt",
    "provider",
    "promptVersion",
    "sourceGameSchemaVersion",
    "pipelineVersion",
    "backgroundColor",
    "inputHashes",
    "sourceFrames",
    "status"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "unitId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "motionIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": ["string", "null"] },
    "seed": { "type": ["integer", "null"] },
    "promptVersion": { "type": "integer", "minimum": 1 },
    "promptHash": { "type": ["string", "null"] },
    "sourceGameSchemaVersion": { "type": "integer", "minimum": 1 },
    "pipelineVersion": { "type": "integer", "minimum": 1 },
    "backgroundColor": { "type": "string", "pattern": "^#[0-9A-F]{6}$" },
    "inputHashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "sourceFrames": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["motionId", "frameIndex", "path", "sha256"],
        "properties": {
          "motionId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "frameIndex": { "type": "integer", "minimum": 0 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "status": {
      "enum": ["generated", "normalized", "validated", "validation-failed", "approved", "published"]
    }
  }
}
