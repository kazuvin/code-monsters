{
  "name": "code-monsters",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "node scripts/browser-smoke.mjs",
    "verify": "pnpm format:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource/pixelify-sans": "latest",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright-core": "^1.61.1",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,jsonc,css,html}": "biome format --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
