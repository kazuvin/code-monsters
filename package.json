{
  "name": "code-monsters",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "balance:simulate": "node --import tsx scripts/simulate-balance.mjs",
    "balance:formula": "node --import tsx scripts/calculate-skill-power.mjs && biome format --write reports/balance/formula.json",
    "balance:formula:check": "node --import tsx scripts/calculate-skill-power.mjs --check",
    "balance:baseline": "node --import tsx scripts/simulate-balance.mjs --output reports/balance/baseline && biome format --write reports/balance/baseline.json",
    "balance:check": "node --import tsx scripts/simulate-balance.mjs --baseline reports/balance/baseline.json --fail-on-regression --output reports/balance/latest",
    "design:matrix": "node --experimental-strip-types scripts/generate-build-matrix.ts",
    "design:matrix:check": "node --experimental-strip-types scripts/generate-build-matrix.ts --check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "test": "vitest run --exclude src/core/balance-simulation.test.ts",
    "test:balance": "vitest run src/core/balance-simulation.test.ts",
    "test:watch": "vitest --exclude src/core/balance-simulation.test.ts",
    "test:browser": "node scripts/browser-smoke.mjs",
    "verify": "pnpm format:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource/pixelify-sans": "latest",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright-core": "^1.61.1",
    "tsx": "^4.23.1",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,jsonc,css,html}": "biome format --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
