{
  "name": "code-monsters",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "verify": "node scripts/verify.mjs",
    "balance:check": "node scripts/balance-check.mjs",
    "debug:data-check": "node scripts/debug-data-test.mjs",
    "test:core": "node scripts/core-test.mjs",
    "test:combat": "node scripts/combat-test.mjs",
    "test:knockback": "node scripts/knockback-test.mjs",
    "test:miss": "node scripts/miss-test.mjs",
    "test:mobile": "node scripts/mobile-ux-test.mjs",
    "test:sniper": "node scripts/sniper-test.mjs",
    "test:ability": "node scripts/ability-test.mjs",
    "test:berserker": "node scripts/berserker-test.mjs",
    "test:jump": "node scripts/jump-test.mjs",
    "test:throw": "node scripts/throw-test.mjs",
    "test:control": "node scripts/control-test.mjs",
    "test:healing": "node scripts/healing-test.mjs",
    "test:cost": "node scripts/cost-test.mjs",
    "test:catalog": "node scripts/catalog-test.mjs",
    "test:debug-room": "node scripts/debug-room-test.mjs",
    "test:poison": "node scripts/poison-test.mjs",
    "test:run": "node scripts/run-test.mjs",
    "test:unity-core": "node scripts/unity-core-check.mjs",
    "test:unity-assets:compile": "node scripts/unity-assets-compile.mjs",
    "test:unity-assets": "node scripts/unity-assets-test.mjs",
    "test:visual": "node scripts/visual-test.mjs",
    "assets:requirements": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts requirements",
    "assets:generate": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts generate",
    "assets:process": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts process",
    "assets:validate": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts validate",
    "assets:preview": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts preview",
    "assets:approve": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts approve",
    "assets:publish": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts publish",
    "assets:check": "pnpm --filter @code-monsters/asset-cli exec node src/cli.ts check",
    "assets:test": "pnpm --filter @code-monsters/asset-cli test",
    "assets:python:setup": "node scripts/python-asset-setup.mjs",
    "assets:python:test": "node scripts/python-asset-tests.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "latest",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright-core": "^1.61.1",
    "wrangler": "latest"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,jsonc,css,html}": "biome format --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
